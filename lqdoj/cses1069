#include <bits/stdc++.h>
using namespace std;

#define ll long long

int main(){
    ios_base::sync_with_stdio(0);cin.tie(0);
    string s; cin >> s;
    int cnt = 1, ans = 0;
    if(s.size() == 1) {cout << 1; return 0;}
    for(int i=1; i<(int)s.size(); ++i){
        if(s[i] == s[i-1]) ++cnt;
        else cnt = 1;
        ans = max(ans, cnt);
    }
    cout << ans;
    return 0;
}
